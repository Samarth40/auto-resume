# ===== ResumeAI Server Environment =====

# Server port
PORT=5050

# --- AI Provider ---
# OpenAI API key. Leave empty to run in MOCK mode (deterministic keyword-based
# analysis/optimization without any API calls — useful for local dev/demo).
OPENAI_API_KEY=

# Model to use (configurable). Examples: gpt-5.5, gpt-4o, gemini-flash-latest
OPENAI_MODEL=gpt-5.5

# Optional: custom base URL (e.g. Azure/OpenRouter/local proxy)
# For Gemini API, use: https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_BASE_URL=

# --- PDF Compilation ---
# Path to pdflatex binary. If it's on PATH, just "pdflatex".
# Windows/MiKTeX (user install) typical path:
#   C:\Users\<you>\AppData\Local\Programs\MiKTeX\miktex\bin\x64\pdflatex.exe
# Install MiKTeX with: winget install --id MiKTeX.MiKTeX
# then enable package auto-install: initexmf --set-config-value=[MPM]AutoInstall=1
PDFLATEX_PATH=pdflatex

# Max time (ms) allowed for a pdflatex run
PDFLATEX_TIMEOUT_MS=60000
